{
  "name": "@aidev/core",
  "version": "0.1.0",
  "description": "Goal-based autonomous AI delivery engine. Drop .aidev/ into any project and describe the goal — aidev works toward it.",
  "type": "module",
  "bin": {
    "aidev": "./dist/cli/index.js"
  },
  "main": "./dist/engine/index.js",
  "types": "./dist/engine/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "autonomous",
    "agent",
    "coding",
    "goal-based",
    "aidev"
  ],
  "license": "MIT"
}
